  let paths: any[] = [];
  Object.keys(db).forEach(catId => {
    const categoria = db[catId as keyof typeof db];
    categoria.farmacos.forEach(farmaco => {
      const relacionados = categoria.farmacos.filter(f => f.id !== farmaco.id);
      paths.push({
        params: { id: farmaco.id },
        props: { farmaco, categoriaNombre: categoria.titulo, categoriaId: catId, colorBadge: categoria.badge, colorText: categoria.text, relacionados }
      });
    });
  });

  return paths;
}

