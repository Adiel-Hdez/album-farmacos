                            </div>
                            <div class="bg-emerald-50/50 p-6 rounded-3xl border border-emerald-100">
                                <h3 class="text-xs font-black uppercase text-emerald-600 tracking-widest mb-3">Cuidados de Enfermería</h3>
                                <ul class="list-disc list-inside text-sm text-slate-700 font-medium space-y-1">
                                    {farmaco.cuidados.map((cuidado: string) => <li class="leading-snug">{cuidado}</li>)}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {relacionados.length > 0 && (
            <div class="mt-16">
                <h3 class="text-sm font-black text-slate-800 uppercase tracking-widest mb-6 border-l-4 pl-3 border-emerald-500">
                    Familia: {categoriaNombre}
                </h3>
                
                <div class="flex overflow-x-auto gap-4 pb-8 snap-x snap-mandatory no-scrollbar bg-white p-5 rounded-3xl shadow-sm border border-slate-100 items-start">
                    {relacionados.map((rel: any) => (
                        <a href={`/farmaco/${rel.id}`} class="snap-start shrink-0 w-40 group">
                            <div class="bg-white p-2 rounded-2xl shadow-sm border border-slate-200 hover:shadow-lg transition-all hover:-translate-y-1 flex flex-col items-center">
                                
                                <div class="w-35 h-35 rounded-xl bg-slate-50 overflow-hidden relative p-2 flex items-center justify-center border border-slate-100 shadow-inner">
