    'corticoesteroides': {
        titulo: 'Corticoesteroides', color: 'bg-orange-500', text: 'text-orange-600', badge: 'bg-orange-500',
        farmacos: [
            { id: 'dexametasona', nombre: 'Dexametasona', presentacion: 'Tabletas 0.5 mg, 4 mg. Ampollas 4 mg/mL y 8 mg/2 mL. Solución oral, Gotas oftálmicas.', indicacion: 'Reacciones alérgicas graves, Asma bronquial, Enfermedades inflamatorias, Edema cerebral, Shock anafiláctico (como parte del tratamiento), Enfermedades autoinmunes, Maduración pulmonar fetal en riesgo de parto prematuro.', farmacodinamia: 'Actúa sobre receptores intracelulares de glucocorticoides, inhibiendo la liberación de mediadores inflamatorios como prostaglandinas y leucotrienos, lo que produce efecto antiinflamatorio, inmunosupresor y antialérgico. Potente acción antiinflamatoria. Disminuye la respuesta inmunológica. Reduce edema e inflamación. Disminuye la liberación de histamina en reacciones alérgicas. Estimula la maduración pulmonar fetal en obstetricia.', farmacocinetica: 'Absorción: buena absorción por vía oral y parenteral. Distribución: amplia distribución en tejidos; atraviesa placenta y barrera hematoencefálica. Metabolismo: hepático. Eliminación: principalmente renal. Vida media: 36–54 horas (acción prolongada).', via: 'Vía oral (VO), Vía intravenosa (IV), Vía intramuscular (IM), Vía intraarticular, Vía oftálmica', dosis: 'General: 0.5 a 10 mg por día VO, IV o IM. Maduración pulmonar fetal: 6 mg IM cada 12 horas por 4 dosis. Dosis máxima depende del protocolo.', contraindicaciones: 'Hipersensibilidad al medicamento, Infecciones sistémicas no tratadas, Úlcera péptica activa, Diabetes descontrolada (precaución).', adversos: ['Hiperglucemia', 'Retención de líquidos', 'Hipertensión', 'Aumento de peso', 'Insomnio', 'Supresión suprarrenal (uso prolongado)'], cuidados: ['Controlar signos vitales.', 'Vigilar niveles de glucosa en sangre.', 'Administrar preferiblemente después de alimentos si es vía oral.', 'No suspender bruscamente en tratamientos prolongados.', 'Vigilar signos de infección.'] }
