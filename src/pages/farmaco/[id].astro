                            {categoriaNombre}
                        </span>
                        <h1 class="text-xl font-black tracking-tight leading-tight text-slate-800">{farmaco.nombre}</h1>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-9 space-y-6">
                <div class="bg-white p-8 md:p-10 rounded-3xl shadow-sm border border-slate-100">
                    <h2 class={`text-xl font-black uppercase italic mb-6 border-b-2 pb-4 border-slate-100 ${colorText}`}>Ficha Farmacológica</h2>
                    
                    <div class="space-y-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                                <h3 class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-2">Presentación</h3>
                                <p class="text-sm font-bold text-slate-700 leading-snug">{farmaco.presentacion}</p>
                            </div>
                            <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                                <h3 class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-2">Vía de Adm. y Dosis Habitual</h3>
                                <p class="text-sm font-bold text-slate-700">{farmaco.via}</p>
                                <p class="text-xs text-slate-500 mt-1">{farmaco.dosis}</p>
                            </div>
                        </div>

                        <div class="grid md:grid-cols-2 gap-x-8 gap-y-8">
                             <div>
                                <h3 class="text-xs font-black uppercase text-slate-400 tracking-widest mb-2">Indicaciones Terapéuticas</h3>
                                <p class="text-slate-600 text-sm font-medium leading-relaxed">{farmaco.indicacion}</p>
                            </div>
                            
                            <div>
                                <h3 class="text-xs font-black uppercase text-slate-400 tracking-widest mb-2">Mecanismo de Acción (Farmacodinamia)</h3>
                                <p class="text-slate-600 text-sm font-medium leading-relaxed">{farmaco.farmacodinamia}</p>
                            </div>

                            <div>
                                <h3 class="text-xs font-black uppercase text-slate-400 tracking-widest mb-2">Farmacocinética</h3>
                                <p class="text-slate-600 text-sm font-medium leading-relaxed">{farmaco.farmacocinetica}</p>
                            </div>
                            
                            <div>
                                <h3 class="text-xs font-black uppercase text-red-400 tracking-widest mb-2">Contraindicaciones</h3>
                                <p class="text-sm leading-relaxed text-red-600 font-bold">{farmaco.contraindicaciones}</p>
                            </div>
                        </div>

                        <div class="grid sm:grid-cols-2 gap-6 pt-6 border-t border-slate-100">
                            <div class="bg-orange-50/50 p-6 rounded-3xl border border-orange-100">
