    <ViewTransitions />
</head>
<body class="bg-[#F8FAFC] min-h-screen text-slate-800 font-sans pb-20">

    <nav class="bg-white border-b border-slate-200 px-6 py-4 shadow-sm">
        <div class="max-w-6xl mx-auto flex justify-between items-center relative z-10">
            <a href={`/categoria/${categoriaId}`} class="text-sm font-bold text-slate-500 hover:text-emerald-600 transition-colors inline-flex items-center group">
                <span class="mr-2 text-lg group-hover:-translate-x-1 transition-transform">←</span> Regresar a {categoriaNombre}
            </a>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 py-8 relative z-0">
        
        <div class="grid lg:grid-cols-12 gap-8 lg:gap-12">
            
            <div class="lg:col-span-3 space-y-6">
                <div class="bg-white p-6 rounded-3xl shadow-lg border border-slate-100 lg:sticky lg:top-24 mx-auto lg:mx-0 text-center">
                    
                    <div class="w-50 h-50 mx-auto bg-slate-50 rounded-2xl flex items-center justify-center p-3 border border-slate-100 shadow-inner overflow-hidden">
                        <img 
                            src={`/${farmaco.id}.jpeg`} 
                            alt={farmaco.nombre} 
                            class="max-w-full max-h-full object-contain drop-shadow-md" 
                            onerror="this.src='https://cdn-icons-png.flaticon.com/512/822/822143.png'" 
                        />
                    </div>
                    
                    <div class="pt-6 pb-4 text-center px-1">
                        <span class={`inline-block px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest text-white mb-3 ${colorBadge}`}>
                            {categoriaNombre}
                        </span>
                        <h1 class="text-xl font-black tracking-tight leading-tight text-slate-800">{farmaco.nombre}</h1>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-9 space-y-6">
                <div class="bg-white p-8 md:p-10 rounded-3xl shadow-sm border border-slate-100">
                    <h2 class={`text-xl font-black uppercase italic mb-6 border-b-2 pb-4 border-slate-100 ${colorText}`}>Ficha Farmacológica</h2>
                    
                    <div class="space-y-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                                <h3 class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-2">Presentación</h3>
                                <p class="text-sm font-bold text-slate-700 leading-snug">{farmaco.presentacion}</p>
                            </div>
                            <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                                <h3 class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-2">Vía de Adm. y Dosis Habitual</h3>
                                <p class="text-sm font-bold text-slate-700">{farmaco.via}</p>
                                <p class="text-xs text-slate-500 mt-1">{farmaco.dosis}</p>
                            </div>
                        </div>

                        <div class="grid md:grid-cols-2 gap-x-8 gap-y-8">
                             <div>
                                <h3 class="text-xs font-black uppercase text-slate-400 tracking-widest mb-2">Indicaciones Terapéuticas</h3>
                                <p class="text-slate-600 text-sm font-medium leading-relaxed">{farmaco.indicacion}</p>
                            </div>
                            
                            <div>
                                <h3 class="text-xs font-black uppercase text-slate-400 tracking-widest mb-2">Mecanismo de Acción (Farmacodinamia)</h3>
                                <p class="text-slate-600 text-sm font-medium leading-relaxed">{farmaco.farmacodinamia}</p>
                            </div>

                            <div>
                                <h3 class="text-xs font-black uppercase text-slate-400 tracking-widest mb-2">Farmacocinética</h3>
                                <p class="text-slate-600 text-sm font-medium leading-relaxed">{farmaco.farmacocinetica}</p>
                            </div>
                            
                            <div>
                                <h3 class="text-xs font-black uppercase text-red-400 tracking-widest mb-2">Contraindicaciones</h3>
                                <p class="text-sm leading-relaxed text-red-600 font-bold">{farmaco.contraindicaciones}</p>
                            </div>
                        </div>

                        <div class="grid sm:grid-cols-2 gap-6 pt-6 border-t border-slate-100">
                            <div class="bg-orange-50/50 p-6 rounded-3xl border border-orange-100">
                                <h3 class="text-xs font-black uppercase text-orange-600 tracking-widest mb-3">Reacciones Adversas</h3>
                                <ul class="list-disc list-inside text-sm text-slate-700 font-medium space-y-1">
                                    {farmaco.adversos.map((adv: string) => <li class="capitalize">{adv}</li>)}
                                </ul>
                            </div>
                            <div class="bg-emerald-50/50 p-6 rounded-3xl border border-emerald-100">
                                <h3 class="text-xs font-black uppercase text-emerald-600 tracking-widest mb-3">Cuidados de Enfermería</h3>
                                <ul class="list-disc list-inside text-sm text-slate-700 font-medium space-y-1">
                                    {farmaco.cuidados.map((cuidado: string) => <li class="leading-snug">{cuidado}</li>)}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {relacionados.length > 0 && (
            <div class="mt-16">
                <h3 class="text-sm font-black text-slate-800 uppercase tracking-widest mb-6 border-l-4 pl-3 border-emerald-500">
                    Familia: {categoriaNombre}
                </h3>
                
                <div class="flex overflow-x-auto gap-4 pb-8 snap-x snap-mandatory no-scrollbar bg-white p-5 rounded-3xl shadow-sm border border-slate-100 items-start">
                    {relacionados.map((rel: any) => (
                        <a href={`/farmaco/${rel.id}`} class="snap-start shrink-0 w-40 group">
                            <div class="bg-white p-2 rounded-2xl shadow-sm border border-slate-200 hover:shadow-lg transition-all hover:-translate-y-1 flex flex-col items-center">
                                
                                <div class="w-35 h-35 rounded-xl bg-slate-50 overflow-hidden relative p-2 flex items-center justify-center border border-slate-100 shadow-inner">
                                    <img 
                                        src={`/${rel.id}.jpeg`} 
                                        alt={rel.nombre} 
                                        class="max-w-full max-h-full object-contain group-hover:scale-110 transition-transform duration-500" 
                                        onerror="this.src='https://cdn-icons-png.flaticon.com/512/822/822143.png'" 
                                    />
                                </div>
                                <h4 class="text-[10px] font-bold text-slate-800 text-center mt-3 mb-1 truncate w-full px-1">{rel.nombre}</h4>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        )}
            <footer class="py-12 text-center text-slate-400 text-[10px] font-bold uppercase tracking-widest">
                Eva Susana Hernández Rivera · 2026
            </footer>

    </main>
</body>
</html>