      paths.push({
        params: { id: farmaco.id },
        props: { farmaco, categoriaNombre: categoria.titulo, categoriaId: catId, colorBadge: categoria.badge, colorText: categoria.text, relacionados }
      });
    });
  });

  return paths;
}

const { farmaco, categoriaNombre, categoriaId, colorBadge, colorText, relacionados } = Astro.props;
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
