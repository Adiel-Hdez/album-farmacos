                                        onerror="this.src='https://cdn-icons-png.flaticon.com/512/822/822143.png'" 
                                    />
                                </div>
                                <h4 class="text-[10px] font-bold text-slate-800 text-center mt-3 mb-1 truncate w-full px-1">{rel.nombre}</h4>
                            </div>
