---
import '../../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

export function getStaticPaths() {
  const db = {
    'analgesicos': { 
        titulo: 'Analgésicos y Antiinflamatorios', color: 'bg-red-500', text: 'text-red-600', badge: 'bg-red-500',
        farmacos: [
            { id: 'acetaminofen', nombre: 'Acetaminofén (Paracetamol)', presentacion: 'Tabletas: 325 mg, 500 mg, 650 mg. Jarabe o suspensión: 120-160 mg/5 ml. Supositorios: 125-500 mg. Solución IV: 1 g/100 ml.', indicacion: 'Fiebre, dolor leve a moderado, cefalea, dolor muscular. En obstetricia: dolor y fiebre en embarazadas.', farmacodinamia: 'Actúa en el SNC inhibiendo la síntesis de prostaglandinas (COX). Antipirético y analgésico. Mínimo efecto antiinflamatorio.', farmacocinetica: 'Absorción rápida GI. Metabolismo hepático. Eliminación renal. Vida media: 2 a 3 horas.', via: 'Oral (VO), Intravenosa (IV), Rectal', dosis: 'Adultos: Máx. 4 g/día. Niños: 10–15 mg/kg/dosis.', contraindicaciones: 'Enfermedad hepática grave, alcoholismo crónico, hipersensibilidad.', adversos: ['Náuseas', 'Vómitos', 'Hepatotoxicidad (sobredosis)'], cuidados: ['Verificar dosis correcta.', 'Evaluar función hepática.', 'No mezclar con otros fármacos con paracetamol.', 'Vigilar toxicidad hepática.'] },
            { id: 'diclofenaco', nombre: 'Diclofenaco', presentacion: 'Tabletas: 25-100 mg (LP). Ampollas: 75 mg/3 ml. Gel 1-2%. Supositorios.', indicacion: 'Dolor leve a moderado, procesos inflamatorios. En ginecología: dolor pélvico y dismenorrea.', farmacodinamia: 'AINE. Inhibe COX-1 y COX-2, disminuyendo prostaglandinas.', farmacocinetica: 'Absorción rápida GI. Alta unión a proteínas. Metabolismo hepático y eliminación renal.', via: 'Oral (VO), IM, Tópica, Rectal', dosis: 'Según indicación médica.', contraindicaciones: 'Hipersensibilidad a AINEs, riesgo de sangrado, úlcera péptica activa.', adversos: ['Irritación gástrica', 'Náuseas', 'Riesgo de sangrado GI'], cuidados: ['Administrar con alimentos.', 'Vigilar signos de sangrado.', 'Controlar función renal.'] },
            { id: 'ketorolaco', nombre: 'Ketorolaco', presentacion: 'Tabletas 10 mg. Inyectable 30 mg/ml. Oftálmica 0.5%.', indicacion: 'Dolor agudo moderado a severo. Riesgo de sangrado.', farmacodinamia: 'AINE. Inhibe de forma no selectiva COX-1 y COX-2.', farmacocinetica: 'Absorción rápida. Metabolismo hepático. Eliminación renal.', via: 'VO, IM, IV, Oftálmica', dosis: 'Según indicación médica.', contraindicaciones: 'Falla renal, úlcera péptica, hemorragia activa.', adversos: ['Dolor gastrointestinal', 'Náuseas', 'Riesgo de sangrado'], cuidados: ['Vigilar sangrado.', 'No exceder días de tratamiento.'] },
            { id: 'indometacina', nombre: 'Indometacina', presentacion: 'Cápsulas 25-50 mg. Supositorios. Solución inyectable.', indicacion: 'Dolor reumático, gota aguda. Cierre de conducto arterioso en neonatos.', farmacodinamia: 'AINE. Inhibe COX reduciendo prostaglandinas.', farmacocinetica: 'Absorción GI. Metabolismo hepático. Eliminación renal y heces.', via: 'Oral (VO), Rectal, IV (Hospital)', dosis: 'Según indicación médica.', contraindicaciones: 'Úlcera activa, embarazo 3er trimestre, falla renal/hepática.', adversos: ['Sangrado GI', 'Cefalea', 'Mareos'], cuidados: ['Administrar con alimentos.', 'Vigilar signos de sangrado.'] },
            { id: 'tramadol', nombre: 'Tramadol', presentacion: 'Cápsulas 50 mg. Inyectable 50 mg/ml. Gotas. Tabletas LP.', indicacion: 'Dolor moderado a severo. Dolor postoperatorio, crónico.', farmacodinamia: 'Opioide de acción central (receptores μ). Inhibe recaptación serotonina/noradrenalina.', farmacocinetica: 'Buena absorción. Metabolismo hepático. Eliminación renal.', via: 'VO, IV, IM, SC', dosis: 'Según indicación médica.', contraindicaciones: 'Depresión respiratoria grave, uso de IMAO, epilepsia no controlada.', adversos: ['Náuseas', 'Somnolencia', 'Estreñimiento'], cuidados: ['Vigilar frecuencia respiratoria (FR).', 'Controlar nivel de conciencia.', 'Evitar consumo de alcohol.'] },
            { id: 'morfina', nombre: 'Morfina', presentacion: 'Ampollas 10 mg/ml. Tabletas. Solución oral.', indicacion: 'Dolor severo agudo, oncológico, IAM, edema agudo de pulmón.', farmacodinamia: 'Opioide potente (receptores μ). Produce analgesia y sedación.', farmacocinetica: 'Metabolismo de primer paso. Atraviesa barrera hematoencefálica (BHE). Eliminación renal.', via: 'IV, IM, SC, VO, Epidural', dosis: 'Estricta prescripción médica.', contraindicaciones: 'Depresión respiratoria grave, asma aguda, TEC.', adversos: ['Depresión respiratoria', 'Estreñimiento', 'Miosis', 'Retención urinaria'], cuidados: ['Vigilar FR (si es <12 rpm no administrar).', 'Tener Naloxona disponible (antídoto).', 'Prevenir y tratar el estreñimiento.'] },
            { id: 'petidina', nombre: 'Petidina (Meperidina)', presentacion: 'Ampollas 50 mg/ml. Tabletas 50-100 mg.', indicacion: 'Dolor moderado a severo, dolor obstétrico.', farmacodinamia: 'Opioide (receptores μ). Menor duración que la morfina. Metabolito tóxico.', farmacocinetica: 'Absorción VO/IM. Metabolizado a normeperidina.', via: 'IV, IM, SC, VO', dosis: 'Según indicación médica.', contraindicaciones: 'Depresión respiratoria, insuficiencia renal grave, uso de IMAO.', adversos: ['Depresión respiratoria', 'Convulsiones (causadas por el metabolito)', 'Hipotensión'], cuidados: ['Vigilar signos de toxicidad neurológica (temblores).', 'Vigilar FR constantemente.', 'Tener Naloxona disponible.'] }
        ] 
    },
    'antibioticos': { 
        titulo: 'Antibióticos', color: 'bg-blue-600', text: 'text-blue-600', badge: 'bg-blue-600',
        farmacos: [
            { id: 'ceftriaxona', nombre: 'Ceftriaxona', presentacion: 'Vial en polvo para reconstituir: 500 mg, 1 g, 2 g.', indicacion: 'Infecciones respiratorias, urinarias, sepsis, meningitis. Profilaxis quirúrgica.', farmacodinamia: 'Cefalosporina de 3ra generación. Bactericida (inhibe síntesis de pared celular).', farmacocinetica: 'Amplia distribución (alcanza el LCR). Eliminación renal/biliar. Vida media: 6-9 hrs.', via: 'Intravenosa (IV), Intramuscular (IM)', dosis: 'Cada 24 horas según indicación médica.', contraindicaciones: 'Hipersensibilidad a cefalosporinas. Neonatos con hiperbilirrubinemia.', adversos: ['Dolor en el sitio de inyección', 'Diarrea', 'Flebitis', 'Candidiasis'], cuidados: ['Verificar alergias previas.', 'Reconstituir correctamente el vial.', 'Administrar muy lentamente por vía IV.'] },
            { id: 'cefazolina', nombre: 'Cefazolina', presentacion: 'Vial en polvo para reconstituir: 500 mg, 1 g, 2 g.', indicacion: 'Infecciones de piel, urinarias. Profilaxis quirúrgica gineco-obstétrica.', farmacodinamia: 'Cefalosporina de 1ra generación. Bactericida contra bacterias grampositivas.', farmacocinetica: 'Buena penetración en tejidos y hueso. Eliminación renal.', via: 'Intravenosa (IV), Intramuscular (IM)', dosis: 'Según indicación médica.', contraindicaciones: 'Hipersensibilidad a cefalosporinas o penicilinas.', adversos: ['Náuseas', 'Flebitis', 'Reacciones alérgicas'], cuidados: ['Verificar alergias del paciente.', 'Administrar lentamente por vía IV.', 'Vigilar aparición de superinfección (candidiasis).'] },
            { id: 'penicilina-sodica', nombre: 'Penicilina Sódica', presentacion: 'Vial en polvo: 1 a 10 millones UI.', indicacion: 'Sífilis, endocarditis, meningitis, neumonía, infecciones ginecológicas.', farmacodinamia: 'Penicilina natural. Bactericida (se une a PBP).', farmacocinetica: 'No se absorbe vía oral. Penetra LCR cuando está inflamado. Eliminación renal.', via: 'Intravenosa (IV), Intramuscular (IM)', dosis: 'Administración frecuente (tiene vida media corta).', contraindicaciones: 'Hipersensibilidad conocida a penicilinas.', adversos: ['Anafilaxia', 'Fiebre', 'Alteraciones electrolíticas'], cuidados: ['Tener siempre el equipo de anafilaxia listo.', 'Administrar lentamente por IV.', 'Controlar la función renal.'] },
            { id: 'penicilina-benzatinica', nombre: 'Penicilina Benzatínica', presentacion: 'Vial/Ampolla prellenada: 600 mil a 2.4 millones UI.', indicacion: 'Sífilis, profilaxis de fiebre reumática, faringitis.', farmacodinamia: 'Penicilina de liberación lenta y prolongada. Bactericida.', farmacocinetica: 'Absorción muy lenta por vía IM. Mantiene niveles en sangre por semanas.', via: 'IM Profunda (⚠️ NUNCA IV)', dosis: 'Dosis única o en esquema serial.', contraindicaciones: 'Hipersensibilidad conocida a penicilinas.', adversos: ['Dolor intenso en la inyección', 'Anafilaxia', 'Reacción de Jarisch-Herxheimer'], cuidados: ['NUNCA administrar por vía intravenosa (IV).', 'Aplicar inyección IM profunda en el glúteo.', 'No masajear el sitio de inyección.'] },
            { id: 'ampicilina', nombre: 'Ampicilina', presentacion: 'Cápsulas, Suspensión oral, Vial parenteral.', indicacion: 'Infecciones respiratorias, urinarias, ruptura prematura de membranas (RPM), sepsis neonatal.', farmacodinamia: 'Aminopenicilina de amplio espectro. Bactericida.', farmacocinetica: 'Absorción VO se ve afectada por alimentos. Eliminación renal.', via: 'Oral (VO), Intravenosa (IV), Intramuscular (IM)', dosis: 'Según indicación médica.', contraindicaciones: 'Hipersensibilidad a penicilinas, mononucleosis infecciosa.', adversos: ['Rash cutáneo', 'Náuseas y diarrea', 'Candidiasis'], cuidados: ['Administrar 1h antes o 2h después de comer si es vía oral.', 'Vigilar alergias y signos de candidiasis.'] },
            { id: 'oxacilina', nombre: 'Oxacilina', presentacion: 'Frasco vial en polvo para reconstituir.', indicacion: 'Infecciones por Staphylococcus sensibles (piel, osteomielitis, endocarditis).', farmacodinamia: 'Penicilina resistente a la penicilinasa. Bactericida.', farmacocinetica: 'Metabolismo hepático parcial. Eliminación renal y biliar.', via: 'Intravenosa (IV), Intramuscular (IM)', dosis: 'Depende de la gravedad de la infección.', contraindicaciones: 'Hipersensibilidad a penicilinas.', adversos: ['Reacciones alérgicas', 'Elevación de enzimas hepáticas', 'Flebitis'], cuidados: ['Administrar lentamente por vía IV.', 'Vigilar el sitio de inyección constantemente.', 'Controlar la función hepática y renal.'] },
            { id: 'gentamicina', nombre: 'Gentamicina', presentacion: 'Solución inyectable, gotas y ungüento oftálmico.', indicacion: 'Sepsis, infecciones urinarias complicadas, neumonía, uso en neonatos.', farmacodinamia: 'Aminoglucósido. Bactericida (inhibe subunidad 30S). Tiene efecto postantibiótico.', farmacocinetica: 'No se absorbe vía oral. Eliminación renal (por filtración glomerular).', via: 'Intravenosa (IV), Intramuscular (IM), Oftálmica', dosis: '3–5 mg/kg/día.', contraindicaciones: 'Hipersensibilidad, miastenia gravis, insuficiencia renal severa.', adversos: ['Nefrotoxicidad', 'Ototoxicidad', 'Bloqueo neuromuscular'], cuidados: ['Controlar niveles de creatinina y BUN.', 'Vigilar la audición del paciente.', 'Administrar IV diluido en 30-60 minutos.'] },
            { id: 'amikacina', nombre: 'Amikacina', presentacion: 'Solución inyectable (100 mg, 500 mg, 1 g).', indicacion: 'Sepsis grave, ITU complicada, bacterias resistentes a otros aminoglucósidos.', farmacodinamia: 'Aminoglucósido. Bactericida. Muy activa contra Pseudomonas.', farmacocinetica: 'No se absorbe vía oral. Eliminación renal.', via: 'Intravenosa (IV), Intramuscular (IM)', dosis: '15 mg/kg/día.', contraindicaciones: 'Hipersensibilidad, falla renal severa, miastenia gravis.', adversos: ['Ototoxicidad', 'Nefrotoxicidad', 'Vértigo y Tinnitus'], cuidados: ['Vigilar estrictamente la función renal y la diuresis.', 'Controlar la audición.', 'Administrar por vía IV lentamente.'] },
            { id: 'clindamicina', nombre: 'Clindamicina', presentacion: 'Cápsulas, inyectable, óvulos, crema vaginal, gel tópico.', indicacion: 'Infecciones de piel, osteomielitis, vaginosis bacteriana, abscesos.', farmacodinamia: 'Lincosamida. Bacteriostático o bactericida. Muy activa contra anaerobios.', farmacocinetica: 'Buena absorción VO. Penetra muy bien en el hueso. Metabolismo hepático.', via: 'Oral (VO), Intravenosa (IV), Intramuscular (IM), Tópica, Vaginal', dosis: 'Máx. diaria: 2,700 mg en infecciones graves.', contraindicaciones: 'Antecedente de colitis asociada a antibióticos.', adversos: ['Colitis pseudomembranosa', 'Diarrea', 'Erupción cutánea'], cuidados: ['Vigilar si presenta diarrea intensa (sospecha de colitis).', 'No administrar nunca en bolo rápido IV.'] },
            { id: 'metronidazol', nombre: 'Metronidazol', presentacion: 'Tabletas, Solución IV, Óvulos, Gel vaginal.', indicacion: 'Vaginosis bacteriana, tricomoniasis, amebiasis, infecciones por anaerobios.', farmacodinamia: 'Nitroimidazol. Bactericida en bacterias anaerobias (altera su ADN).', farmacocinetica: 'Excelente absorción VO. Atraviesa BHE y placenta. Metabolismo hepático.', via: 'Oral (VO), Intravenosa (IV), Vaginal, Tópica', dosis: 'Máximo 4 g/día.', contraindicaciones: 'Consumo de alcohol, 1er trimestre de embarazo (precaución).', adversos: ['Sabor metálico', 'Náuseas', 'Orina oscura', 'Efecto disulfiram con el alcohol'], cuidados: ['Prohibir terminantemente consumir alcohol durante y 48h post tratamiento.', 'Administrar diluido por IV en 30-60 minutos.'] }
        ] 
    },
    'gastrointestinales': {
        titulo: 'Gastrointestinales', color: 'bg-emerald-500', text: 'text-emerald-600', badge: 'bg-emerald-500',
        farmacos: [
            { id: 'ranitidina', nombre: 'Ranitidina', presentacion: 'Tabletas: 150 mg, 300 mg. Jarabe: 15 mg/ml. Ampolla inyectable: 50 mg/2 ml VIM, VIV.', indicacion: 'Úlcera gástrica, Úlcera duodenal, Enfermedad por reflujo gastroesofágico (ERGE), Síndrome de Zollinger-Ellison, Prevención de úlceras por estrés, Gastritis.', farmacodinamia: 'Bloquea los receptores H2 de histamina en las células parietales del estómago, lo que disminuye la secreción de ácido gástrico, tanto basal como estimulada por alimentos, histamina o gastrina. Esto reduce la acidez del jugo gástrico y favorece la cicatrización de la mucosa gástrica.', farmacocinetica: 'Absorción: buena absorción por vía oral. Inicio de acción: aproximadamente 1 hora. Distribución: se distribuye ampliamente en los tejidos corporales. Metabolismo: hepático parcial. Eliminación: principalmente por vía renal. Vida media: aproximadamente 2–3 horas.', via: 'Oral (VO), Intravenosa (IV), Intramuscular (IM)', dosis: 'Adultos: VO: 150 mg cada 12 horas o 300 mg una vez al día. IV/IM: 50 mg cada 6 a 8 horas. Dosis máxima: 300 mg al día por vía oral en la mayoría de tratamientos.', contraindicaciones: 'Hipersensibilidad al medicamento. Precaución en insuficiencia renal o hepática. Uso con precaución en embarazo y lactancia.', adversos: ['Dolor de cabeza', 'Mareos', 'Náuseas', 'Diarrea o estreñimiento', 'Confusión (más frecuente en adultos mayores)', 'Reacciones alérgicas (raras)'], cuidados: ['Verificar los cinco correctos antes de administrar el medicamento.', 'Evaluar síntomas de dolor epigástrico, acidez o reflujo antes y durante el tratamiento.', 'Administrar la ranitidina antes de las comidas o por la noche si es por vía oral.', 'En administración intravenosa, aplicar lentamente para evitar efectos adversos.', 'Vigilar signos de sangrado gastrointestinal (hematemesis o melena).', 'Valorar función renal, especialmente en pacientes adultos mayores.', 'Educar al paciente para evitar alcohol, tabaco y alimentos irritantes que aumentan la secreción gástrica.', 'Informar que debe completar el tratamiento indicado para lograr la cicatrización de la mucosa.'] }
        ]
    },
    'antiemeticos': {
        titulo: 'Antieméticos', color: 'bg-teal-500', text: 'text-teal-600', badge: 'bg-teal-500',
        farmacos: [
            { id: 'dimenhidrinato', nombre: 'Dimenhidrinato', presentacion: 'Tabletas 50 mg, Jarabe o suspensión oral, Solución inyectable 50 mg/mL VIM, VIB, Supositorios VR.', indicacion: 'Náuseas y vómitos, Vértigo, Mareo por movimiento (cinetosis), Prevención y tratamiento del vómito postoperatorio, Trastornos del equilibrio.', farmacodinamia: 'Bloquea los receptores H1 de histamina y tiene efecto anticolinérgico sobre el sistema vestibular y el centro del vómito en el cerebro. Produce efecto antiemético, antivertiginoso y sedante. Disminuye la estimulación del aparato vestibular. Reduce la transmisión nerviosa hacia el centro del vómito en el bulbo raquídeo. Puede causar depresión leve del sistema nervioso central.', farmacocinetica: 'Absorción: Buena absorción por vía oral. Distribución: Se distribuye ampliamente en tejidos y atraviesa la barrera hematoencefálica. Metabolismo: Metabolismo hepático. Eliminación: Se elimina principalmente por orina. Vida media: Aproximadamente 3–6 horas.', via: 'Oral (VO), Intramuscular (IM), Intravenosa (IV), Rectal', dosis: '50–100 mg cada 4–6 horas vía oral o IM/IV según indicación. Dosis máxima diaria: 400 mg/día.', contraindicaciones: 'Hipersensibilidad al fármaco, Glaucoma de ángulo cerrado, Hipertrofia prostática, Recién nacidos, Precaución en embarazo y lactancia.', adversos: ['Somnolencia', 'Mareo', 'Sequedad de boca', 'Visión borrosa', 'Retención urinaria', 'Estreñimiento'], cuidados: ['Vigilar somnolencia o sedación.', 'Advertir al paciente evitar conducir o manejar maquinaria pesada.', 'Administrar preferiblemente antes de viajes si se usa para cinetosis.', 'Controlar signos de retención urinaria en adultos mayores.', 'Vigilar respuesta al tratamiento de náuseas y vómitos.'] },
            { id: 'metoclopramida', nombre: 'Metoclopramida', presentacion: 'Tabletas 10 mg, Solución oral (jarabe), Ampollas 10 mg/2 mL para administración IV o IM.', indicacion: 'Náuseas y vómitos, Gastroparesia (especialmente diabética), Reflujo gastroesofágico, Prevención de vómitos postoperatorios, Preparación para procedimientos radiológicos del tracto gastrointestinal.', farmacodinamia: 'Bloquea los receptores dopaminérgicos D2 en el sistema nervioso central, especialmente en el centro del vómito. Además, aumenta la motilidad gastrointestinal, favoreciendo el vaciamiento gástrico y el tránsito intestinal. Actúa como antiemético al bloquear los receptores D2 en la zona gatillo quimiorreceptora. Tiene efecto procinético, aumentando el tono del esfínter esofágico inferior y la motilidad gástrica. Acelera el vaciamiento gástrico y mejora el tránsito intestinal superior. Disminuye náuseas y vómitos de diversas causas.', farmacocinetica: 'Absorción: Buena absorción por vía oral (aprox. 80%). Distribución: Se distribuye ampliamente en los tejidos y atraviesa la barrera hematoencefálica y la placenta. Metabolismo: Metabolismo hepático. Eliminación: Se excreta principalmente por vía renal. Vida media: Aproximadamente 5–6 horas.', via: 'Oral (VO), Intramuscular (IM), Intravenosa (IV)', dosis: '10 mg cada 6–8 horas por vía oral, IM o IV. Dosis máxima diaria: 40 mg/día.', contraindicaciones: 'Hipersensibilidad al medicamento, Hemorragia gastrointestinal, Obstrucción o perforación intestinal, Epilepsia, Enfermedad de Parkinson, Feocromocitoma.', adversos: ['Somnolencia', 'Fatiga', 'Inquietud', 'Diarrea', 'Reacciones extrapiramidales (distonía, espasmos musculares)', 'Hiperprolactinemia'], cuidados: ['Vigilar aparición de reacciones extrapiramidales.', 'Administrar IV lentamente (mínimo 1–2 minutos).', 'Evaluar alivio de náuseas y vómitos.', 'Vigilar signos de diarrea o dolor abdominal.', 'Tener precaución en pacientes con enfermedades neurológicas.'] }
        ]
    },
    'antiespasmodicos': {
        titulo: 'Antiespasmódicos', color: 'bg-lime-600', text: 'text-lime-700', badge: 'bg-lime-600',
        farmacos: [
            { id: 'bromuro-hioscina', nombre: 'Bromuro de N-butilhioscina', presentacion: 'Tabletas 10 mg, Solución inyectable 20 mg/mL (IV o IM), Supositorios.', indicacion: 'Cólicos gastrointestinales, Cólicos biliares, Cólicos renales, Espasmos del tracto urinario, Síndrome de intestino irritable, Espasmos uterinos.', farmacodinamia: 'Bloquea los receptores muscarínicos del músculo liso, produciendo relajación del músculo liso del tracto gastrointestinal, biliar, urinario y uterino, disminuyendo los espasmos. Produce efecto antiespasmódico sobre el músculo liso. Reduce los espasmos del tracto gastrointestinal, urinario y biliar. Disminuye el dolor tipo cólico. Tiene efecto anticolinérgico periférico.', farmacocinetica: 'Absorción: Absorción limitada por vía oral. Distribución: Se distribuye principalmente en tejidos del tracto gastrointestinal y órganos abdominales. No atraviesa fácilmente la barrera hematoencefálica. Metabolismo: Metabolismo hepático parcial. Eliminación: Se elimina principalmente por vía renal y en menor proporción por heces. Vida media: Aproximadamente 5 horas.', via: 'Oral (VO), Intramuscular (IM), Intravenosa (IV), Rectal', dosis: 'Vía oral: 10–20 mg cada 6–8 horas. Vía IM o IV: 20 mg según necesidad. Dosis máxima diaria: 100 mg/día.', contraindicaciones: 'Hipersensibilidad al medicamento, Glaucoma de ángulo cerrado, Miastenia gravis, Megacolon, Obstrucción intestinal.', adversos: ['Sequedad de boca', 'Taquicardia', 'Visión borrosa', 'Retención urinaria', 'Estreñimiento'], cuidados: ['Vigilar frecuencia cardíaca.', 'Observar signos de retención urinaria.', 'Vigilar respuesta al tratamiento del dolor tipo cólico.', 'Administrar IV lentamente.', 'Tener precaución en pacientes con glaucoma o problemas prostáticos.'] }
        ]
    },
    'uterotonicos': {
        titulo: 'Uterotónicos', color: 'bg-pink-500', text: 'text-pink-600', badge: 'bg-pink-500',
        farmacos: [
            { id: 'oxitocina', nombre: 'Oxitocina', presentacion: 'Ampollas 5 UI/mL, Ampollas 10 UI/mL. Para administración IV o IM.', indicacion: 'Inducción del trabajo de parto, Estimulación o conducción del parto, Prevención y tratamiento de hemorragia postparto, Favorecer la expulsión de la placenta, Involución uterina después del parto.', farmacodinamia: 'Estimula los receptores de oxitocina en el músculo liso del útero, produciendo contracciones uterinas rítmicas. También favorece la eyección de la leche materna al contraer las células mioepiteliales de las glándulas mamarias. Produce contracciones uterinas fuertes y rítmicas. Aumenta la intensidad y frecuencia de las contracciones durante el trabajo de parto. Favorece la involución uterina después del parto. Disminuye el sangrado postparto al comprimir los vasos uterinos.', farmacocinetica: 'Absorción: Se administra por vía IV o IM. Distribución: Se distribuye rápidamente en el líquido extracelular. Metabolismo: Se metaboliza principalmente en hígado y riñón por la enzima oxitocinasa. Eliminación: Se elimina por riñón y en menor proporción por hígado. Vida media: Aproximadamente 3–5 minutos.', via: 'Intravenosa (IV), Intramuscular (IM)', dosis: 'Inducción (IV): 1–2 mU/min en infusión. Prevención hemorragia: 10 UI IM después del alumbramiento. Tratamiento hemorragia: 10–40 UI en 1000 mL de solución IV. Dosis máxima: ajustada según respuesta uterina.', contraindicaciones: 'Desproporción cefalopélvica, Sufrimiento fetal, Presentación fetal anormal, Placenta previa, Riesgo de ruptura uterina, Hipersensibilidad al fármaco.', adversos: ['Maternas: Hipertonicidad uterina, Ruptura uterina (raro), Hipotensión, Náuseas y vómitos', 'Fetales: Sufrimiento fetal, Asfixia fetal por contracciones excesivas'], cuidados: ['Vigilar frecuencia, intensidad y duración de las contracciones uterinas.', 'Monitorizar frecuencia cardíaca fetal.', 'Controlar signos de hiperestimulación uterina.', 'Vigilar signos vitales maternos.', 'Administrar con bomba de infusión para control preciso.', 'Tener disponible equipo para manejo de emergencia obstétrica.'] },
            { id: 'ergonovina', nombre: 'Ergonovina', presentacion: 'Tabletas 0.2 mg, Ampollas 0.2 mg/mL para administración IM o IV.', indicacion: 'Prevención de hemorragia postparto, Tratamiento de hemorragia uterina postparto, Favorecer la involución uterina después del parto. ⚠ No se usa para inducir el trabajo de parto.', farmacodinamia: 'Estimula directamente el músculo liso del útero, produciendo contracciones uterinas fuertes y sostenidas. Actúa sobre receptores serotoninérgicos y alfa-adrenérgicos, aumentando el tono uterino. Produce contracciones uterinas intensas y prolongadas. Aumenta el tono basal del útero. Disminuye el sangrado postparto al comprimir los vasos uterinos. Tiene efecto vasoconstrictor sobre vasos sanguíneos.', farmacocinetica: 'Absorción: Buena absorción por vía oral e IM. La vía IV produce efecto rápido. Distribución: Se distribuye ampliamente en tejidos. Metabolismo: Metabolismo hepático. Eliminación: Se excreta principalmente por bilis y en menor proporción por orina. Vida media: Aproximadamente 30 minutos a 2 horas.', via: 'Oral (VO), Intramuscular (IM), Intravenosa (IV)', dosis: '0.2 mg IM o IV después de la expulsión de la placenta. Puede repetirse cada 2–4 horas si es necesario. Dosis máxima: 1 mg en 24 horas.', contraindicaciones: 'Hipertensión arterial, Preeclampsia o eclampsia, Enfermedad cardiovascular, Embarazo antes del parto, Hipersensibilidad al fármaco.', adversos: ['Hipertensión arterial', 'Cefalea', 'Náuseas y vómitos', 'Dolor abdominal', 'Vasoespasmo', 'Mareo'], cuidados: ['Controlar presión arterial antes y después de la administración.', 'Vigilar sangrado uterino.', 'Evaluar tono y contracción del útero.', 'No administrar antes de la expulsión de la placenta.', 'Vigilar signos de hipertensión o vasoespasmo.'] },
            { id: 'misoprostol', nombre: 'Misoprostol', presentacion: 'Tabletas 200 microgramos (mcg).', indicacion: 'Inducción del trabajo de parto, Maduración cervical, Tratamiento de hemorragia postparto, Manejo de aborto incompleto, Prevención de úlceras gástricas por AINEs.', farmacodinamia: 'Estimula los receptores de prostaglandinas en el músculo liso del útero, provocando contracciones uterinas y favoreciendo la dilatación cervical. También disminuye la secreción de ácido gástrico y aumenta la producción de moco protector en la mucosa gástrica. Produce contracciones uterinas. Favorece la maduración cervical. Disminuye el sangrado uterino al contraer el útero. Protege la mucosa gástrica frente a AINEs.', farmacocinetica: 'Absorción: rápida por vía oral, sublingual y vaginal. Distribución: amplia distribución en tejidos. Metabolismo: hepático a su metabolito activo (ácido misoprostólico). Eliminación: principalmente renal. Vida media: 20–40 minutos.', via: 'Vía oral, Vía sublingual, Vía vaginal, Vía rectal, Vía bucal (entre encía y mejilla)', dosis: 'Inducción del parto: 25 mcg vía vaginal cada 4–6 horas. Hemorragia postparto: 600–800 mcg vía oral, sublingual o rectal. Aborto incompleto: 600–800 mcg. Dosis máxima: Generalmente 800 mcg por dosis.', contraindicaciones: 'Hipersensibilidad al medicamento, Embarazo cuando se usa para prevención de úlceras, Desproporción cefalopélvica, Precaución en cicatriz uterina previa.', adversos: ['Dolor abdominal', 'Diarrea', 'Náuseas', 'Fiebre', 'Escalofríos', 'Contracciones uterinas excesivas'], cuidados: ['Vigilar contracciones uterinas.', 'Monitorizar frecuencia cardíaca fetal.', 'Vigilar signos de hemorragia uterina.', 'Controlar signos vitales.', 'Registrar respuesta al tratamiento.'] }
